rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Autoridad por CUSTOM CLAIM en el token (`role`), NO por firestore.get cross-service:
    // la lectura Storage→Firestore falla silenciosamente en este proyecto y devuelve 403 en
    // cada subida. El claim lo setea scripts/create-staff.mjs vía setCustomUserClaims({role}).
    // (Patrón del equipo: autoridad en el claim, no en el doc — ver security_rules skill.)
    function isEditor() {
      return request.auth != null
        && request.auth.token.role in ['admin', 'editor'];
    }
    match /images/{allPaths=**} {
      allow read: if true;                                  // imágenes públicas del sitio
      allow write: if isEditor()
        && request.resource.size < 8 * 1024 * 1024          // máx 8MB
        && request.resource.contentType.matches('image/.*');
    }
  }
}
