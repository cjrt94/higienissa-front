rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function profile() { return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data; }
    function isEditor() {
      return request.auth != null && profile().active == true &&
        (profile().role == 'admin' || profile().role == 'editor');
    }
    match /images/{allPaths=**} {
      allow read: if true;                                  // imágenes públicas del sitio
      allow write: if isEditor()
        && request.resource.size < 8 * 1024 * 1024          // máx 8MB
        && request.resource.contentType.matches('image/.*');
    }
  }
}
