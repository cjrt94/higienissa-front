# ============================================================
# Grupo Higienissa — variables de entorno (copiar a .env)
# ============================================================

# URL pública del sitio (para canonical / hreflang / OG)
NUXT_PUBLIC_SITE_URL=https://higienissa.com

# --- Firebase (web config, cliente) — pegar desde la consola de Firebase ---
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# --- Solo server / build (NO se exponen al cliente) ---
# Service account JSON (string) para leer Firestore en prerender/SSR
FIREBASE_SERVICE_ACCOUNT=
# Deploy Hook URL de Vercel (la Cloud Function publishPage la llama para rebuild on-publish)
VERCEL_DEPLOY_HOOK=
